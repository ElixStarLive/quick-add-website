# Server Configuration
PORT=3000
NODE_ENV=production

# Your live site URL (no trailing slash)
SITE_URL=https://quickpostads.co.uk

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate_a_long_random_secret_here
SESSION_SECRET=generate_another_long_random_secret_here

# Database (Railway: use ./quickpost.db or mount a volume)
DATABASE_PATH=./quickpost.db
